<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!--
      Prevent ASP.NET managed modules from pre-consuming the request body
      for Classic ASP pages. This is the standard fix for:
        "Operation not Allowed" on Request.BinaryRead
      which occurs when a managed module reads Request.Form first.
    -->
    <modules runAllManagedModulesForAllRequests="false" />
  </system.webServer>
</configuration>
